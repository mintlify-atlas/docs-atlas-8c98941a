  "keyFeatures": [
    "Raycast extension compatibility with @raycast/api shims",
    "Voice input with hold-to-speak dictation (Wispr Flow style)",
    "Text-to-speech for selected text (Speechify style)",
    "AI integration with Ollama, OpenAI, and Anthropic",
    "Memory-aware AI with Supermemory integration",
    "Native macOS window management and hotkeys",
    "Clipboard history management",
    "Snippet expansion",
    "Script command support",
    "Extension discovery and installation from Raycast store"
  ],
  "publicApiSurface": [
    "List - Full component with filtering, pagination, detail view",
    "Detail - Component with metadata support",
    "Form - All field types including DatePicker, FilePicker",
    "Grid - Grid layout with sections and accessories",
    "ActionPanel - Action panel with submenu support",
    "Action - Open, Push, CopyToClipboard, ToggleQuickLook",
    "MenuBarExtra - Menu bar integration",
    "useNavigation - Push/pop navigation stack",
    "showToast - Toast notifications",
    "showHUD - HUD overlay",
    "confirmAlert - Alert dialogs",
    "open - Open URLs and applications",
    "closeMainWindow - Window management",
    "popToRoot - Navigation reset",
    "launchCommand - Command launching",
    "getSelectedText - Get selected text from macOS",
    "getApplications - List installed applications",
    "getFrontmostApplication - Get active application",
    "Clipboard - Clipboard operations",
    "LocalStorage - Persistent storage",
    "Cache - Caching system",
    "AI - AI integration with streaming support",
    "useFetch - HTTP fetching with pagination",
    "useCachedPromise - Promise caching",
    "useForm - Form state management",
    "useExec - Command execution",
    "useSQL - SQLite queries",
    "useAI - AI streaming hook"
  ]
}
